---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
  image?: string;
  type?: "website" | "article";
  robots?: string;
}

const {
  title,
  description = "Writing, photography, and experiments.",
  wide = false,
  image = "/og/default.png",
  type = "website",
  robots,
} = Astro.props;
const pathname = Astro.url.pathname;

const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);

const pageTitle = title === "Home" ? "Matthew R. Kenney" : `${title} · Matthew R. Kenney`;
const canonicalURL = Astro.url.href;
const imageURL = new URL(image, Astro.url.origin).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Matthew R. Kenney</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:site_name" content="Matthew R. Kenney" />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class={`site ${wide ? "site--wide" : ""}`}>
      <nav class="nav">
        <a class="nav__name" href="/">Matthew R. Kenney</a>
        <ul class="nav__links">
          <li><a href="/writing" aria-current={isActive("/writing") ? "page" : undefined}>Writing</a></li>
          <li><a href="/photography" aria-current={isActive("/photography") ? "page" : undefined}>Photography</a></li>
          <li><a href="/experiments" aria-current={isActive("/experiments") ? "page" : undefined}>Experiments</a></li>
          <li><a href="/about" aria-current={isActive("/about") ? "page" : undefined}>About</a></li>
        </ul>
      </nav>
      <main>
        <slot />
      </main>
      <footer class="footer">
        &copy; {new Date().getFullYear()} Matthew R. Kenney
      </footer>
    </div>
  </body>
</html>
