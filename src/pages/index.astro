---

import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";

const featuredMovie = {
  title: "Sorcerer",
  year: "1977",
  imdb: "https://www.imdb.com/title/tt0076740/",
  cartoon: "sorcerer",
  description: "Sorcerer (1977) is William Friedkin's hidden gem. While it's a remake of The Wages of Fear, that label doesn't do it justice. Four men from different backgrounds end up in a decaying South American oil town: a getaway driver, a French banker, a Palestinian militant, and a hitman. They all hide from pasts that catch up with them. When a well catches fire in the jungle, one man must drive two hundred miles of treacherous mountain roads with a truckload of unstable dynamite. The pay offers a way out, but most won't make it. Friedkin uses the first act to show how each man earned his spot in hell. By the time the trucks roll, you realize the drive isn't just about money. It's about men trying to escape fate in vehicles that could kill them at any moment. The film's climax features two forty-ton trucks crossing a rope bridge in a raging storm. They creep across a crumbling span over a boiling river, creating one of the most terrifying scenes ever filmed. There are no CGI tricks, only months of hardship that almost derailed the production. Tangerine Dream's electronic score transforms the jungle into something eerie and cosmic. The title reflects this; it's painted on a truck, but Friedkin uses it to symbolize fate itself, an evil sorcerer nobody can escape. The film is bleak and deliberate, pushing boundaries and ending with a cruel twist. Audiences in 1977 wanted Star Wars but got a grim existential tale instead. It flopped and marked the end of Friedkin's golden era. Time has proven them wrong.",
};

const allSeries = await getCollection("photography", ({ data }) => !data.draft);
const nightPhotography = allSeries.find((entry) => entry.id === "night-photography");
const nightPhotoCover = nightPhotography?.data.cover;
---

<BaseLayout title="Home">
  <section>
    <h1>Matthew R. Kenney</h1>
    <p class="lede">
      Notes, photographs, writing experiments (I'm applying to grad school and need writing samples). I work in innovation management, which mostly means watching ideas collide, lately a lot of them about AI. Your idea doesn't have to be good, but you should share it anyway. This site is me taking my own advice: built from scratch in Claude Code, no other companies involved, just Claude and Cloudflare.
    </p>
  </section>

  <section style="margin-top: 2.5rem;">
    <h2>Featured movie</h2>
    <article style="margin-bottom: 1.5rem;">
      <h3 style="margin: 0 0 0.25rem 0; font-size: 1.25rem; font-weight: 600;">
        <a href={featuredMovie.imdb} target="_blank" rel="noopener" style="text-decoration: none; color: inherit;">
          {featuredMovie.title}
        </a>
      </h3>
      <p style="margin: 0 0 1.25rem 0; font-size: 0.875rem; color: var(--color-ink-soft);">{featuredMovie.year}</p>

      <div style="margin: 1.5rem 0; max-width: 550px;">
        <img
          src={`/movie-cartoon-${featuredMovie.cartoon}.svg`}
          alt={`Cartoon for ${featuredMovie.title}`}
          loading="lazy"
          style="width: 100%; height: auto; display: block; border: 1px solid #e8e8e6; border-radius: 2px;"
        />
      </div>

      <p style="margin-top: 1.5rem; line-height: 1.6;">{featuredMovie.description}</p>
    </article>
    <p><a href="/movies">All movies &rarr;</a></p>
  </section>

  {nightPhotography && (
    <section style="margin-top: 2.5rem;">
      <h2>Featured photos</h2>
      <a class="gallery-card" href="/photography/night-photography">
        {nightPhotoCover && (
          <Image src={nightPhotoCover} alt={nightPhotography.data.title} width={800} loading="lazy" />
        )}
        <span class="gallery-card__title">{nightPhotography.data.title}</span>
      </a>
      <p><a href="/photography/night-photography">Explore night photography &rarr;</a></p>
    </section>
  )}
</BaseLayout>
