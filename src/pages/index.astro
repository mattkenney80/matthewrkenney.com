---
export const prerender = false;

import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";

const featuredMovie = {
  title: "Sexy Beast",
  year: "2000",
  imdb: "https://www.imdb.com/title/tt0274518/",
  cartoon: "sexy-beast",
  description: "Sexy Beast might be the most beautiful film ever made about a man who just wants to be left alone. Every frame looks incredible. The baking Spanish sun, the impossibly blue pool, a boulder rolling down the hill in the first five minutes like a bad omen with a great cinematographer. Gal Dove did the impossible. He got out. Did his time, made his money, retired to a villa with the woman he loves and a tan he earned. He finished on top, which almost nobody in his trade ever does. Then Don Logan shows up. Ben Kingsley plays him as pure menace in a golf shirt, a psychopath who takes the word \"no\" as a personal insult, and one of the great screen villains because he never needs a weapon when he can just wear you down instead. That's the whole film. One man's small perfect paradise against a force of nature that wants him back in the muck. Gorgeous, tense, remarkable.",
};

const allSeries = await getCollection("photography", ({ data }) => !data.draft);
const nightPhotography = allSeries.find((entry) => entry.id === "night-photography");
const nightPhotoCover = nightPhotography?.data.cover;
---

<BaseLayout title="Home">
  <section>
    <h1>Matthew R. Kenney</h1>
    <p class="lede">
      Notes, photographs, experiments. I work in innovation management, which mostly
      means watching ideas collide. Lately with AI ethics, which is mostly the question
      of who's responsible when they do. Your idea doesn't have to be good; you should
      share it anyway. This site is me taking my own advice.
    </p>
  </section>

  <section style="margin-top: 2.5rem;">
    <h2>Featured movie</h2>
    <article style="margin-bottom: 1.5rem;">
      <h3 style="margin: 0 0 0.25rem 0; font-size: 1.25rem; font-weight: 600;">
        <a href={featuredMovie.imdb} target="_blank" rel="noopener" style="text-decoration: none; color: inherit;">
          {featuredMovie.title}
        </a>
      </h3>
      <p style="margin: 0 0 1.25rem 0; font-size: 0.875rem; color: var(--color-ink-soft);">{featuredMovie.year}</p>

      <div style="margin: 1.5rem 0; max-width: 550px;">
        <img
          src={`/movie-cartoon-${featuredMovie.cartoon}.svg`}
          alt={`Cartoon for ${featuredMovie.title}`}
          loading="lazy"
          style="width: 100%; height: auto; display: block; border: 1px solid #e8e8e6; border-radius: 2px;"
        />
      </div>

      <p style="margin-top: 1.5rem; line-height: 1.6;">{featuredMovie.description}</p>
    </article>
    <p><a href="/movies">All movies &rarr;</a></p>
  </section>

  {nightPhotography && (
    <section style="margin-top: 2.5rem;">
      <h2>Featured photos</h2>
      <a class="gallery-card" href="/photography/night-photography">
        {nightPhotoCover && (
          <Image src={nightPhotoCover} alt={nightPhotography.data.title} width={800} loading="lazy" />
        )}
        <span class="gallery-card__title">{nightPhotography.data.title}</span>
      </a>
      <p><a href="/photography/night-photography">Explore night photography &rarr;</a></p>
    </section>
  )}
</BaseLayout>
