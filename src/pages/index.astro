---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("writing", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const recentPosts = posts.slice(0, 3);

const series = (await getCollection("photography", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const featured = series[0];
---

<BaseLayout title="Home">
  <section>
    <h1>Matthew R. Kenney</h1>
    <p class="lede">
      Writing, photography, and whatever else I'm tinkering with. This site is a
      place to publish notes often and show a few photos I like.
    </p>
  </section>

  {recentPosts.length > 0 && (
    <section style="margin-top: 2.5rem;">
      <h2>Recent writing</h2>
      <ul class="post-list">
        {recentPosts.map((post) => (
          <li>
            <a class="post-list__title" href={`/writing/${post.id}`}>{post.data.title}</a>
            <p class="meta">{post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
          </li>
        ))}
      </ul>
      <p><a href="/writing">All writing &rarr;</a></p>
    </section>
  )}

  {featured && (
    <section style="margin-top: 2.5rem;">
      <h2>Featured photos</h2>
      <a class="gallery-card" href={`/photography/${featured.id}`}>
        {featured.data.cover && (
          <Image src={featured.data.cover} alt={featured.data.title} width={900} />
        )}
        <span class="gallery-card__title">{featured.data.title}</span>
      </a>
      <p><a href="/photography">All photography &rarr;</a></p>
    </section>
  )}
</BaseLayout>
