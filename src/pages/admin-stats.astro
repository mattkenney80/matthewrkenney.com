---
export const prerender = false;

import { env } from "cloudflare:workers";
import BaseLayout from "../layouts/BaseLayout.astro";
import { validateSession } from "../lib/auth";

const { DB, SESSION } = env;

// Check authentication
const cookie = Astro.request.headers.get("cookie");
const sessionId = cookie?.split("admin_session=")[1]?.split(";")[0];
const isAuthenticated = await validateSession(SESSION, sessionId);

if (!isAuthenticated) {
  return Astro.redirect("/admin/login");
}

// Get or create stats table
let viewCount = 0;
try {
  const result = await DB.prepare(
    "SELECT view_count FROM page_stats WHERE page_name = 'admin_stats' LIMIT 1"
  ).first();

  viewCount = result?.view_count ?? 0;

  // Increment the counter
  await DB.prepare(
    "INSERT INTO page_stats (page_name, view_count) VALUES ('admin_stats', 1) ON CONFLICT(page_name) DO UPDATE SET view_count = view_count + 1"
  ).run();

  // Get updated count
  const updated = await DB.prepare(
    "SELECT view_count FROM page_stats WHERE page_name = 'admin_stats' LIMIT 1"
  ).first();
  viewCount = updated?.view_count ?? 1;
} catch (e) {
  // Table might not exist yet, that's ok
  console.log("Stats table not ready");
}
---

<BaseLayout title="Admin Stats" description="Page statistics" robots="noindex, nofollow">
  <div style="max-width: 600px; margin: 2rem auto; padding: 2rem; border: 1px solid #e5e2da; border-radius: 4px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
      <h1 style="margin: 0; font-size: 2rem;">Page Statistics</h1>
      <form method="POST" action="/admin/logout" style="margin: 0;">
        <button
          type="submit"
          style="padding: 0.5rem 1rem; background: #e5e2da; color: #1a1a1a; border: none; border-radius: 4px; font-size: 0.875rem; cursor: pointer; transition: opacity 0.2s;"
          onmouseover="this.style.opacity='0.7'"
          onmouseout="this.style.opacity='1'"
        >
          Logout
        </button>
      </form>
    </div>

    <div style="padding: 2rem; background: #fdfdfb; border-radius: 4px; text-align: center;">
      <p style="margin: 0 0 1rem 0; color: #55534d; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.05em;">
        Total Views
      </p>
      <p style="margin: 0; font-size: 3rem; font-weight: 600; color: #1a1a1a;">
        {viewCount}
      </p>
    </div>

    <p style="margin-top: 2rem; color: #55534d; font-size: 0.875rem;">
      This page counts every visit. Updated in real-time.
    </p>

    <p style="color: #55534d; font-size: 0.75rem; margin-top: 1rem;">
      🔒 Protected • Not indexed by search engines • Requires authentication
    </p>
  </div>

  <style>
    :global(body) {
      background: #fdfdfb;
    }
  </style>
</BaseLayout>
