---
export const prerender = false;

import { env } from "cloudflare:workers";
import { EmailMessage } from "cloudflare:email";
import { createMimeMessage, Mailbox } from "mimetext/browser";
import BaseLayout from "../layouts/BaseLayout.astro";

let sent = false;
let error: string | undefined;
let draft = { name: "", email: "", city: "", favorites: "" };

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const name = String(form.get("name") ?? "").trim();
  const email = String(form.get("email") ?? "").trim();
  const city = String(form.get("city") ?? "").trim();
  const favorites = String(form.get("favorites") ?? "").trim();
  const honeypot = String(form.get("website") ?? "").trim();

  draft = { name, email, city, favorites };

  if (honeypot) {
    // Bot filled the hidden field; pretend everything worked.
    sent = true;
  } else if (!name || !email || !city || !favorites) {
    error = "All fields are required.";
  } else {
    try {
      const msg = createMimeMessage();
      msg.setSender({ name: "matthewrkenney.com", addr: "contact@matthewrkenney.com" });
      msg.setRecipient("matthew.kenney80@gmail.com");
      msg.setHeader("Reply-To", new Mailbox({ addr: email, name }));
      msg.setSubject(`Contact form: ${name}`);
      msg.addMessage({
        contentType: "text/plain",
        data: `Name: ${name}\nEmail: ${email}\nCity: ${city}\n\nFavorite Band, Book or Movie (or all):\n${favorites}\n`,
      });

      await env.CONTACT_EMAIL.send(
        new EmailMessage(
          "contact@matthewrkenney.com",
          "matthew.kenney80@gmail.com",
          msg.asRaw()
        )
      );
      sent = true;
    } catch (e) {
      console.error("Contact form send failed:", e);
      error = "Something went wrong sending your message. Please try again later.";
    }
  }
}
---

<BaseLayout title="Contact" description="Get in touch with Matthew R. Kenney.">
  <h1>Contact</h1>

  {sent ? (
    <>
      <div class="envelope" role="status">
        <span class="clasp" aria-hidden="true"></span>

        <p class="kicker">Message received</p>

        <p class="message">
          Your message has been received and placed in a manila envelope on a desk in
          a room where nobody works. Someone will find it.
        </p>

        <hr class="rule" />

        <span class="stamp">REF <span id="ref">——</span></span>

        <p class="footnote">
          Quote this number in any follow-up. It will not help, but it will be quoted.
        </p>
      </div>
      <p style="margin-top: 2rem;"><a href="/">&larr; Back home</a></p>
      <script is:inline>
        // A reference that is absurdly precise and genuinely unique per submission.
        // Format: MF-YYDDD-HHMM-XX   (MF = manila file, DDD = day of year)
        function reference(d = new Date()) {
          const pad = (n, w = 2) => String(n).padStart(w, "0");
          const start = Date.UTC(d.getFullYear(), 0, 0);
          const day = Math.floor((Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()) - start) / 86400000);
          const rand = Math.random().toString(36).slice(2, 4).toUpperCase();
          return `MF-${pad(d.getFullYear() % 100)}${pad(day, 3)}-${pad(d.getHours())}${pad(d.getMinutes())}-${rand}`;
        }

        document.getElementById("ref").textContent = reference();
      </script>
    </>
  ) : (
    <>
      <p class="lede">Have something to say? I read everything that comes through here.</p>
      {error && <p class="admin-notice">{error}</p>}
      <form method="POST" style="max-width: var(--measure);">
        <div class="field">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" value={draft.name} required />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input type="text" id="email" name="email" value={draft.email} required />
        </div>
        <div class="field">
          <label for="city">City</label>
          <input type="text" id="city" name="city" value={draft.city} required />
        </div>
        <div class="field">
          <label for="favorites">What is your favorite Band, Book or Movie or all?</label>
          <textarea id="favorites" name="favorites" rows="6" required>{draft.favorites}</textarea>
        </div>
        <div class="field" style="position: absolute; left: -9999px;" aria-hidden="true">
          <label for="website">Website</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
        </div>
        <div class="form-actions">
          <button class="btn btn--primary" type="submit">Send</button>
        </div>
      </form>
    </>
  )}
</BaseLayout>

<style>
  .envelope {
    --manila: #d8c295;
    --manila-dark: #b9a077;
    --envelope-ink: #2b2620;
    --envelope-ink-soft: #6a6157;
    --stamp: #7c2f24;

    position: relative;
    width: 100%;
    max-width: 520px;
    margin-top: 2.5rem;
    padding: 3rem 2.25rem 2.25rem;
    background: var(--manila);
    border: 1px solid var(--manila-dark);
    border-radius: 2px;
    box-shadow: 0 1px 0 #c9b085 inset, 0 18px 40px -22px rgba(43, 38, 32, .55);
    color: var(--envelope-ink);
    font-family: "Iowan Old Style", "Palatino Linotype", Palatino, Georgia, serif;
  }

  /* the clasp: one small piece of envelope hardware, nothing more */
  .clasp {
    position: absolute;
    top: -9px;
    left: 50%;
    transform: translateX(-50%);
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--manila-dark);
    border: 1px solid #9c8462;
  }

  .kicker {
    margin: 0 0 1.5rem;
    font-family: "Courier New", Courier, monospace;
    font-size: 11px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--envelope-ink-soft);
  }

  .message {
    margin: 0;
    font-size: 1.3rem;
    line-height: 1.55;
    letter-spacing: .01em;
  }

  .rule {
    margin: 2rem 0 1.25rem;
    border: 0;
    border-top: 1px dashed var(--manila-dark);
  }

  /* signature element: the reference, stamped slightly crooked */
  .stamp {
    display: inline-block;
    padding: .45rem .8rem;
    border: 2px solid var(--stamp);
    border-radius: 3px;
    transform: rotate(-1.6deg);
    color: var(--stamp);
    font-family: "Courier New", Courier, monospace;
    font-size: 13px;
    letter-spacing: .1em;
    opacity: .82;
  }

  .footnote {
    margin: 1.25rem 0 0;
    font-family: "Courier New", Courier, monospace;
    font-size: 12px;
    line-height: 1.6;
    color: var(--envelope-ink-soft);
  }

  @media (max-width: 480px) {
    .envelope { padding: 2.5rem 1.5rem 1.75rem; }
    .message { font-size: 1.15rem; }
  }

  @media (prefers-reduced-motion: no-preference) {
    .envelope { animation: settle .45s cubic-bezier(.2, .7, .3, 1) both; }
    @keyframes settle {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: none; }
    }
  }
</style>
