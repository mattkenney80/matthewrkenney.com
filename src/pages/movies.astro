---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";

const movies: { title: string; year: string; imdb: string; description: string }[] = [
  {
    title: "Margin Call",
    year: "2011",
    imdb: "https://www.imdb.com/title/tt1615147/",
    description: "Margin Call is probably my favorite movie about finance. It's criminally underrated, but those who know it light up when you mention it, like you've found a fellow member of a small club. The story unfolds in about four rooms over a single sleepless night, and it never feels small. There's no crash montage or chaotic trading floor, just people in offices talking. Somehow, that's more tense than any thriller with a body count. Every performance is top-notch, and Jeremy Irons plays one of the most incredible characters in film history. He's so good as the CEO that I often have to pause the movie just to absorb what he's doing before I can continue. Sometimes, I'll go to YouTube and watch him speak in that movie, no plot, no context, just him talking. It's an unbelievable film, and one of my favorite scenes features Kevin Spacey in Brooklyn Heights. He talks about being an engineer and building a bridge, counting all the years and lives he supposedly saved with it. He thinks he has a profound point, and then Paul Bettany cuts in with, Some people want to take the long ride home, and it's brilliant. That exchange captures the essence of the whole movie. Every grand justification meets a flat, honest line that deflates it. It's one of the best movies ever made, and I'd argue nothing else comes close to capturing the quiet, bloodless way real money actually blows up.",
  },
  {
    title: "Sorcerer",
    year: "1977",
    imdb: "https://www.imdb.com/title/tt0076740/",
    description: "Sorcerer (1977) is William Friedkin's hidden gem. While it's a remake of The Wages of Fear, that label doesn't do it justice. Four men from different backgrounds end up in a decaying South American oil town: a getaway driver, a French banker, a Palestinian militant, and a hitman. They all hide from pasts that catch up with them. When a well catches fire in the jungle, one man must drive two hundred miles of treacherous mountain roads with a truckload of unstable dynamite. The pay offers a way out, but most won't make it. Friedkin uses the first act to show how each man earned his spot in hell. By the time the trucks roll, you realize the drive isn't just about money. It's about men trying to escape fate in vehicles that could kill them at any moment. The film's climax features two forty-ton trucks crossing a rope bridge in a raging storm. They creep across a crumbling span over a boiling river, creating one of the most terrifying scenes ever filmed. There are no CGI tricks, only months of hardship that almost derailed the production. Tangerine Dream's electronic score transforms the jungle into something eerie and cosmic. The title reflects this; it's painted on a truck, but Friedkin uses it to symbolize fate itself, an evil sorcerer nobody can escape. The film is bleak and deliberate, pushing boundaries and ending with a cruel twist. Audiences in 1977 wanted Star Wars but got a grim existential tale instead. It flopped and marked the end of Friedkin's golden era. Time has proven them wrong.",
  },
  {
    title: "Enter the Void",
    year: "2009",
    imdb: "https://www.imdb.com/title/tt0387564/",
    description: "Enter the Void (2009) is Gaspar Noé's challenge to look away. The film's nerve lies in its camera work. We don't just watch Oscar, a young dealer in neon Tokyo. We see through his eyes, blinks and all. Then, twenty minutes in, he's shot dead. The film pulls its best trick: the camera keeps moving. It lifts off his corpse and turns into a spirit, floating over the city. It phases through walls and revisits his memories like a ghost that can't let go. This impossible motion is key. Drawing from the Tibetan Book of the Dead, Noé shows a dead man's perspective. It follows one stubborn consciousness circling its wreckage: the grief, the drugs, and the sister he can't leave behind. This journey drifts toward something like rebirth. You don't follow a story; you experience a mind dissolving. Noé ensures you feel death from the inside, not just as a spectator.",
  },
  {
    title: "Sexy Beast",
    year: "2000",
    imdb: "https://www.imdb.com/title/tt0274518/",
    description: "Sexy Beast might be the most beautiful film ever made about a man who just wants to be left alone. Every frame looks incredible. The baking Spanish sun, the impossibly blue pool, a boulder rolling down the hill in the first five minutes like a bad omen with a great cinematographer. Gal Dove did the impossible. He got out. Did his time, made his money, retired to a villa with the woman he loves and a tan he earned. He finished on top, which almost nobody in his trade ever does. Then Don Logan shows up. Ben Kingsley plays him as pure menace in a golf shirt, a psychopath who takes the word \"no\" as a personal insult, and one of the great screen villains because he never needs a weapon when he can just wear you down instead. That's the whole film. One man's small perfect paradise against a force of nature that wants him back in the muck. Gorgeous, tense, remarkable.",
  },
  {
    title: "Michael Clayton",
    year: "2007",
    imdb: "https://www.imdb.com/title/tt0465538/",
    description: "George Clooney plays a law firm's janitor, the guy who mops up messes for men richer than he will ever be. It's a legal thriller, technically, but really it's about being middle-aged in corporate America and realizing you took your one shot and missed. The question the movie asks is what's left of a man after that, and the answer, delivered in a silent cab ride over the closing credits, is: maybe just enough.",
  },
  {
    title: "Rogue Trader",
    year: "1999",
    imdb: "https://www.imdb.com/title/tt0140352/",
    description: "Ewan McGregor plays Nick Leeson, the trader who vaporized Barings Bank, a 233-year-old institution, from a desk in Singapore. The plot is simple: get cocky, dig a hole, lie about the hole, dig faster. Not a masterpiece, but a perfect little fable about the secret account where we all stash our losses, and what happens when the bill finally clears.",
  },
  {
    title: "Dear Zachary: A Letter to a Son About His Father",
    year: "2008",
    imdb: "https://www.imdb.com/title/tt1152758/",
    description: "I'm not going to tell you what happens. Kurt Kuenne set out to make a scrapbook film about his murdered best friend, Andrew Bagby, for the son Andrew never got to meet. Usually in these stories the man is the monster. Not this time. Andrew was, by every account, one of the good ones, and what happened to his family is the hardest thing a documentary has ever asked me to sit through. It will make you cry. Watch it anyway.",
  },
  {
    title: "Wonder Boys",
    year: "2000",
    imdb: "https://www.imdb.com/title/tt0185037/",
    description: "Michael Douglas as a pot-smoking novelist seven years and two thousand pages into a book that refuses to end. The most honest movie about creative work I know, because it admits that most of the artistic life isn't inspiration, it's driving around Pittsburgh with a dead dog in your trunk while your editor asks how it's coming. Warm, shaggy, and criminally underseen.",
  },
  {
    title: "Shotgun Stories",
    year: "2007",
    imdb: "https://www.imdb.com/title/tt0850644/",
    description: "Jeff Nichols' first film, and within five minutes you know you're watching an auteur. Michael Shannon and his brothers (Son, Boy, and Kid, which is what their father bothered to name them) go to war with the second family their dad raised after he sobered up and became somebody else's good father. It's a movie about dads, mostly the craters they leave. Quiet, Southern, and it goes off exactly like its title.",
  },
  {
    title: "Overnight",
    year: "2003",
    imdb: "https://www.imdb.com/title/tt0390622/",
    description: "A documentary about Troy Duffy, the Boston bartender Harvey Weinstein handed a movie deal, a record deal, and half a bar, and who torched every bit of it through sheer ego. A man given too much who appreciated none of it. It plays like a Greek tragedy, not to sound like a hack, except the gods are Miramax and the fatal flaw is being insufferable. Beautiful, in its awful way.",
  },
];
---

<BaseLayout title="Movie Recommendations" description="Movies worth your time, with links to IMDB.">
  <h1>Movie Recommendations</h1>
  <p class="lede">A running list of films worth your time.</p>

  <div class="movies-list" style="margin-top: 1.5rem;">
    {movies.map((movie, index) => {
      const cartoonMap: { [key: number]: string } = {
        0: "margin-call",
        1: "sorcerer",
        2: "enter-the-void",
        3: "sexy-beast",
        4: "michael-clayton",
        5: "rogue-trader",
        6: "dear-zachary",
        7: "wonder-boys",
        8: "shotgun-stories",
        9: "overnight",
      };
      return (
        <article class="movie-card">
          <h2>
            <a href={movie.imdb} target="_blank" rel="noopener" style="text-decoration: none; color: inherit;">
              {movie.title}
            </a>
          </h2>
          <p class="meta">{movie.year}</p>

          <div class="movie-cartoon">
            <img
              src={`/movie-cartoon-${cartoonMap[index]}.svg`}
              alt={`Cartoon for ${movie.title}`}
              loading="lazy"
            />
          </div>

          <p style="margin-top: 1.5rem; line-height: 1.6;">{movie.description}</p>
        </article>
      );
    })}
  </div>

  <style>
    .movie-card {
      margin-bottom: 2.5rem;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid var(--color-border);
    }

    .movie-card:last-child {
      border-bottom: none;
    }

    .movie-card h2 {
      margin: 0 0 0.5rem 0;
      font-size: 1.25rem;
      font-weight: 600;
    }

    .movie-card a:hover {
      text-decoration: underline;
    }

    .movie-card .meta {
      margin: 0 0 1.25rem 0;
    }

    .movie-cartoon {
      margin: 1.5rem 0;
      max-width: 550px;
    }

    .movie-cartoon img {
      width: 100%;
      height: auto;
      display: block;
      border: 1px solid #e8e8e6;
      border-radius: 2px;
    }
  </style>
</BaseLayout>
