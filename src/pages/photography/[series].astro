---
import { getCollection, render } from "astro:content";
import { Image, getImage } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Lightbox from "../../components/Lightbox.astro";

export async function getStaticPaths() {
  const series = await getCollection("photography", ({ data }) => !data.draft);
  return series.map((entry) => ({
    params: { series: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const photos = await Promise.all(
  entry.data.photos.map(async (photo) => {
    const nativeWidth = photo.src.width;
    const [full, download] = await Promise.all([
      getImage({ src: photo.src, width: Math.min(nativeWidth, 2400) }),
      getImage({ src: photo.src, width: nativeWidth, format: "jpg", quality: 95 }),
    ]);
    return { ...photo, full, download };
  })
);
---

<BaseLayout title={entry.data.title} description={entry.data.description} wide>
  <article>
    <h1>{entry.data.title}</h1>
    <p class="meta">
      {entry.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
    </p>
    {entry.data.description && <p class="lede">{entry.data.description}</p>}

    {photos.length === 0 ? (
      <p class="meta" style="margin-top: 1.5rem;">No photos yet — check back soon.</p>
    ) : (
      <div class="gallery-grid" style="margin-top: 1.5rem;">
        {photos.map((photo) => (
          <figure>
            <button
              class="photo-trigger"
              type="button"
              data-full={photo.full.src}
              data-download={photo.download.src}
              data-alt={photo.alt}
              data-caption={photo.caption ?? ""}
            >
              <Image src={photo.src} alt={photo.alt} width={800} loading="lazy" />
            </button>
            {photo.caption && <figcaption>{photo.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}

    <div class="prose" style="margin-top: 2rem;">
      <Content />
    </div>
  </article>
  <p><a href="/photography">&larr; All photography</a></p>

  <Lightbox />
</BaseLayout>
