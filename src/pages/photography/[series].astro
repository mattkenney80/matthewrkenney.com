---
export const prerender = false;

import { getEntry, render } from "astro:content";
import { Image, getImage } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Lightbox from "../../components/Lightbox.astro";

const entry = await getEntry("photography", Astro.params.series);

if (!entry || entry.data.draft) {
  Astro.response.status = 404;
  return await Astro.rewrite("/404");
}

const { Content } = await render(entry);
const hasIntro = Boolean(entry.body && entry.body.trim());

const ogImage = entry.data.cover
  ? (await getImage({ src: entry.data.cover, width: 1200, height: 630, fit: "cover", format: "jpg" })).src
  : undefined;

const photos = await Promise.all(
  entry.data.photos.map(async (photo) => {
    const nativeWidth = photo.src.width;
    const [full, download] = await Promise.all([
      getImage({ src: photo.src, width: Math.min(nativeWidth, 2400) }),
      getImage({ src: photo.src, width: nativeWidth, format: "jpg", quality: 95 }),
    ]);
    return { ...photo, full, download };
  })
);
---

<BaseLayout title={entry.data.title} description={entry.data.description} image={ogImage} type="article" wide>
  <article>
    <h1>{entry.data.title}</h1>
    <p class="meta">
      {entry.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
    </p>
    {entry.data.description && <p class="lede">{entry.data.description}</p>}

    {hasIntro && (
      <div class="prose gallery-intro">
        <Content />
      </div>
    )}

    {photos.length === 0 ? (
      <p class="meta" style="margin-top: 1.5rem;">No photos yet — check back soon.</p>
    ) : (
      <div class="gallery-grid" style="margin-top: 1.5rem;">
        {photos.map((photo) => (
          <figure>
            <button
              class="photo-trigger"
              type="button"
              data-full={photo.full.src}
              data-download={photo.download.src}
              data-alt={photo.alt}
              data-caption={photo.caption ?? ""}
            >
              <Image src={photo.src} alt={photo.alt} width={800} loading="lazy" />
            </button>
            {photo.caption && <figcaption>{photo.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}
  </article>
  <p><a href="/photography">&larr; All photography</a></p>

  <Lightbox />
</BaseLayout>
