---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";

const series = (await getCollection("photography", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Photography" description="Photo series and galleries." wide>
  <h1>Photography</h1>
  {series.length === 0 ? (
    <p class="lede">Nothing published yet.</p>
  ) : (
    <div class="series-grid">
      {series.map((entry) => (
        <a class="gallery-card" href={`/photography/${entry.id}`}>
          {entry.data.cover && (
            <Image src={entry.data.cover} alt={entry.data.title} width={640} />
          )}
          <span class="gallery-card__title">{entry.data.title}</span>
          <p class="meta">{entry.data.photos.length} photo{entry.data.photos.length === 1 ? "" : "s"}</p>
        </a>
      ))}
    </div>
  )}
</BaseLayout>
