---
export const prerender = false;

import { env } from "cloudflare:workers";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { articleTags, formatDate, type Article } from "../../lib/articles";

const { DB } = env;
const { results } = await DB.prepare(
  "SELECT * FROM articles WHERE published = 1 ORDER BY date DESC, id DESC"
).all<Article>();
const posts = results ?? [];
---

<BaseLayout title="Writing" description="Essays, notes, and short posts.">
  <h1>Writing</h1>
  {posts.length === 0 ? (
    <p class="lede">Nothing published yet.</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a class="post-list__title" href={`/writing/${post.slug}`}>{post.title}</a>
          <p class="meta">{formatDate(post.date)}</p>
          {post.description && <p>{post.description}</p>}
          {articleTags(post).map((tag) => <span class="tag">{tag}</span>)}
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
