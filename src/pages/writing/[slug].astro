---
export const prerender = false;

import { env } from "cloudflare:workers";
import { marked } from "marked";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { articleTags, formatDate, type Article } from "../../lib/articles";

const { DB } = env;
const post = await DB.prepare(
  "SELECT * FROM articles WHERE slug = ? AND published = 1"
)
  .bind(Astro.params.slug)
  .first<Article>();

if (!post) {
  // Serve the prerendered 404 page (Astro.rewrite can't target a static
  // route from an on-demand one under "server" output).
  try {
    const asset = await env.ASSETS.fetch(new URL("/404.html", Astro.url));
    return new Response(asset.body, {
      status: 404,
      headers: { "Content-Type": "text/html; charset=utf-8" },
    });
  } catch {
    return new Response("Not found", { status: 404 });
  }
}

const html = marked.parse(post.body);
---

<BaseLayout
  title={post.title}
  description={post.description ?? undefined}
  image={`/og/writing/${post.slug}.png`}
  type="article"
>
  <article>
    <h1>{post.title}</h1>
    <p class="meta">{formatDate(post.date)}</p>
    {articleTags(post).map((tag) => <span class="tag">{tag}</span>)}
    <div class="prose" style="margin-top: 1.5rem;" set:html={html} />
  </article>
  <p><a href="/writing">&larr; All writing</a></p>
</BaseLayout>
