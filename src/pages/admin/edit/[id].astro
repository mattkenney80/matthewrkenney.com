---
export const prerender = false;

import { env } from "cloudflare:workers";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArticleForm from "../../../components/ArticleForm.astro";
import { slugify, type Article } from "../../../lib/articles";

const { DB } = env;
const { id } = Astro.params;
let error: string | undefined;
let draft: Article | undefined;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const title = String(form.get("title") ?? "").trim();
  const rawSlug = String(form.get("slug") ?? "").trim();
  const slug = slugify(rawSlug || title);
  const description = String(form.get("description") ?? "").trim();
  const tags = String(form.get("tags") ?? "").trim();
  const date = String(form.get("date") ?? "").trim();
  const body = String(form.get("body") ?? "");
  const published = form.get("published") ? 1 : 0;

  draft = { id: Number(id), title, slug, description, tags, date, body, published } as Article;

  if (!title || !slug || !date) {
    error = "Title, slug, and date are required.";
  } else {
    try {
      await DB.prepare(
        `UPDATE articles
         SET slug = ?, title = ?, description = ?, tags = ?, date = ?, body = ?, published = ?, updated_at = CURRENT_TIMESTAMP
         WHERE id = ?`
      )
        .bind(slug, title, description || null, tags, date, body, published, id)
        .run();
      return Astro.redirect("/admin");
    } catch (err) {
      error = `That slug ("${slug}") is already in use — pick another.`;
    }
  }
}

const article = draft ?? (await DB.prepare("SELECT * FROM articles WHERE id = ?").bind(id).first<Article>());

if (!article) {
  Astro.response.status = 404;
  return await Astro.rewrite("/404");
}
---

<BaseLayout title={`Edit · ${article.title}`}>
  <h1>Edit article</h1>
  <ArticleForm action={`/admin/edit/${id}`} article={article} error={error} />
</BaseLayout>
