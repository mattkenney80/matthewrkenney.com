---
export const prerender = false;

import { env } from "cloudflare:workers";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleForm from "../../components/ArticleForm.astro";
import { slugify, type Article } from "../../lib/articles";

const { DB } = env;
let error: string | undefined;
let draft: Article | undefined;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const title = String(form.get("title") ?? "").trim();
  const rawSlug = String(form.get("slug") ?? "").trim();
  const slug = slugify(rawSlug || title);
  const description = String(form.get("description") ?? "").trim();
  const tags = String(form.get("tags") ?? "").trim();
  const date = String(form.get("date") ?? "").trim();
  const body = String(form.get("body") ?? "");
  const published = form.get("published") ? 1 : 0;

  draft = { title, slug, description, tags, date, body, published } as Article;

  if (!title || !slug || !date) {
    error = "Title, slug, and date are required.";
  } else {
    try {
      await DB.prepare(
        `INSERT INTO articles (slug, title, description, tags, date, body, published, updated_at)
         VALUES (?, ?, ?, ?, ?, ?, ?, CURRENT_TIMESTAMP)`
      )
        .bind(slug, title, description || null, tags, date, body, published)
        .run();
      return Astro.redirect("/admin");
    } catch (err) {
      error = `That slug ("${slug}") is already in use — pick another.`;
    }
  }
}
---

<BaseLayout title="New article">
  <h1>New article</h1>
  <ArticleForm action="/admin/new" article={draft} error={error} />
</BaseLayout>
