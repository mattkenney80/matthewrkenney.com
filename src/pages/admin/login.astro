---
export const prerender = false;

import { env } from "cloudflare:workers";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { createSession, verifyPassword } from "../../lib/auth";

let error = "";
let success = false;

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const password = formData.get("password") as string;

  if (verifyPassword(password, env)) {
    const { SESSION } = env;
    const sessionId = await createSession(SESSION);

    // Set cookie
    Astro.response.headers.set(
      "Set-Cookie",
      `admin_session=${sessionId}; Path=/; HttpOnly; Secure; SameSite=Strict; Max-Age=${7 * 24 * 60 * 60}`
    );

    success = true;
  } else {
    error = "Invalid password";
  }
}

if (success) {
  return Astro.redirect("/admin");
}
---

<BaseLayout title="Admin Login" description="Admin login" robots="noindex, nofollow">
  <div style="max-width: 400px; margin: 4rem auto; padding: 2rem; border: 1px solid #e5e2da; border-radius: 4px;">
    <h1 style="margin: 0 0 1.5rem 0; font-size: 1.5rem;">Admin Login</h1>

    {error && (
      <div style="padding: 1rem; background: #fce4e4; border: 1px solid #f5a5a5; border-radius: 4px; margin-bottom: 1rem; color: #c82333;">
        {error}
      </div>
    )}

    <form method="POST" style="display: flex; flex-direction: column; gap: 1rem;">
      <div style="display: flex; flex-direction: column; gap: 0.5rem;">
        <label for="password" style="font-size: 0.875rem; font-weight: 500;">Password</label>
        <input
          id="password"
          type="password"
          name="password"
          required
          style="padding: 0.75rem; border: 1px solid #e5e2da; border-radius: 4px; font-family: inherit; font-size: 1rem;"
          autofocus
        />
      </div>
      <button
        type="submit"
        style="padding: 0.75rem 1.5rem; background: #1a1a1a; color: white; border: none; border-radius: 4px; font-size: 1rem; font-weight: 500; cursor: pointer; transition: opacity 0.2s;"
        onmouseover="this.style.opacity='0.8'"
        onmouseout="this.style.opacity='1'"
      >
        Sign In
      </button>
    </form>

    <p style="margin-top: 1.5rem; color: #55534d; font-size: 0.875rem;">
      Protected admin area. Unauthorized access attempts are logged.
    </p>
  </div>
</BaseLayout>
